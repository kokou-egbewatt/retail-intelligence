# Copy to .env and fill in your values. Never commit .env.
# OPENROUTER_API_KEY=sk-or-v1-your-key-here
# OPENROUTER_MODEL=openai/gpt-4o-mini

# Offline: load embedding model from cache only (no Hugging Face network).
# Set to 1 if you have no internet or DNS issues. Model must be cached first (run indexing once with network).
# HF_HUB_OFFLINE=1
# TRANSFORMERS_OFFLINE=1
